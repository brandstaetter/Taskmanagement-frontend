{
  "name": "frontend",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "prestart": "node scripts/sync-openapi.mjs",
    "start": "ng serve",
    "prestart:dev": "node scripts/sync-openapi.mjs",
    "start:dev": "ng serve --configuration=development",
    "prestart:prod": "node scripts/sync-openapi.mjs",
    "start:prod": "ng serve --configuration=production",
    "prebuild": "node scripts/sync-openapi.mjs",
    "build": "ng build",
    "prebuild:prod": "node scripts/sync-openapi.mjs",
    "build:prod": "ng build --configuration=production",
    "watch": "ng build --watch --configuration development",
    "pretest": "node scripts/sync-openapi.mjs",
    "test": "jest",
    "pretest:ci": "node scripts/sync-openapi.mjs",
    "test:ci": "jest --ci",
    "pretest:coverage": "node scripts/sync-openapi.mjs",
    "test:coverage": "jest --coverage",
    "lint": "ng lint && eslint \"src/**/*.ts\"",
    "lint:fix": "ng lint --fix && eslint \"src/**/*.ts\" --fix",
    "e2e": "playwright test",
    "e2e:smoke": "playwright test --project=smoke",
    "e2e:headed": "playwright test --headed",
    "analyze": "ng build --stats-json && webpack-bundle-analyzer dist/frontend/stats.json",
    "clean": "rimraf dist node_modules",
    "clean:dist": "rimraf dist",
    "format": "prettier --write \"src/**/*.{ts,html,scss}\"",
    "format:check": "prettier --check \"src/**/*.{ts,html,scss}\"",
    "sonar": "npm run test:coverage && sonar-scanner",
    "sonar:local": "npm run test:coverage && sonar-scanner -Dsonar.host.url=http://localhost:9000",
    "prepare": "husky",
    "pre-commit": "lint-staged"
  },
  "lint-staged": {
    "src/**/*.{ts,html,scss}": [
      "prettier --write"
    ],
    "src/**/*.ts": [
      "eslint --fix"
    ]
  },
  "private": true,
  "engines": {
    "node": ">=24.0.0",
    "npm": ">=11.6.0"
  },
  "dependencies": {
    "@angular/animations": "^21.0.0",
    "@angular/cdk": "^21.0.0",
    "@angular/common": "^21.0.0",
    "@angular/compiler": "^21.0.0",
    "@angular/core": "^21.0.0",
    "@angular/forms": "^21.0.0",
    "@angular/material": "^21.0.0",
    "@angular/platform-browser": "^21.0.0",
    "@angular/platform-browser-dynamic": "^21.0.0",
    "@angular/router": "^21.0.0",
    "rxjs": "~7.8.2",
    "tslib": "^2.3.0",
    "zone.js": "~0.16.0"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "^21.0.0",
    "@angular/cli": "^21.0.0",
    "@angular/compiler-cli": "^21.0.0",
    "@eslint/js": "^10.0.0",
    "@hey-api/openapi-ts": "^0.96.0",
    "@types/jest": "^30.0.0",
    "angular-eslint": "^21.0.0",
    "esbuild": ">=0.25.0",
    "eslint": "^10.0.0",
    "eslint-config-prettier": "^10.0.1",
    "eslint-plugin-prettier": "^5.2.3",
    "husky": "^9.1.7",
    "jest": "^30.3.0",
    "jest-environment-jsdom": "^30.3.0",
    "jest-preset-angular": "^16.1.1",
    "lint-staged": "^16.0.0",
    "prettier": "^3.5.1",
    "rimraf": "^6.0.1",
    "sonarqube-scanner": "^4.3.0",
    "typescript": "~6.0.2",
    "typescript-eslint": "8.58.2",
    "@playwright/test": "^1.52.0",
    "webpack-bundle-analyzer": "^5.0.0"
  }
}
